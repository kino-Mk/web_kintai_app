rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 従業員データ
    match /employees/{employeeId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.get('id', '') is string
                            && request.resource.data.get('name', '') is string;
    }

    // 打刻データ
    match /attendance/{docId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.get('empId', '') is string 
                            && request.resource.data.get('type', '') in ['in', 'out']
                            && request.resource.data.get('timestamp', request.time) is timestamp;
    }

    // 申請データ
    match /applications/{applicationId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.get('empId', '') is string
                            && request.resource.data.get('status', '') in ['pending', 'approved', 'rejected', 'completed'];
    }

    // 休日カレンダーデータ
    match /holidays/{dateString} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.get('name', '') is string;
    }

    // 有給付与履歴
    match /leaveGrants/{grantId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.get('empId', '') is string
                            && (request.resource.data.get('days', 0) is number || request.resource.data.get('days', '') is string);
    }

    // システム設定
    match /system/{docId} {
      allow read, delete: if true;
      allow create, update: if true; // 柔軟性確保
    }

    // パスワードリセットトークン
    match /passwordResetTokens/{tokenId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.get('empId', '') is string
                            && request.resource.data.get('token', '') is string;
    }

    // 打刻修正申請
    match /stampCorrections/{correctionId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.get('empId', '') is string
                            && request.resource.data.get('status', '') in ['pending', 'approved', 'rejected', 'completed'];
    }

    // エラーログ
    match /errorLogs/{logId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.get('message', '') is string;
    }
  }
}
