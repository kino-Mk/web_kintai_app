rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 従業員データ
    match /employees/{employeeId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.id is string
                            && request.resource.data.name is string;
    }

    // 打刻データ
    match /attendance/{docId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.empId is string 
                            && request.resource.data.type in ['in', 'out']
                            && request.resource.data.timestamp is timestamp;
    }

    // 申請データ
    match /applications/{applicationId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.empId is string
                            && request.resource.data.status in ['pending', 'approved', 'rejected', 'completed'];
    }

    // 休日カレンダーデータ
    match /holidays/{dateString} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.name is string;
    }

    // 有給付与履歴
    match /leaveGrants/{grantId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.empId is string
                            && (request.resource.data.days is number || request.resource.data.days is string);
    }

    // システム設定
    match /system/{docId} {
      allow read, delete: if true;
      allow create, update: if true; // 柔軟性確保
    }

    // パスワードリセットトークン
    match /passwordResetTokens/{tokenId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.empId is string
                            && request.resource.data.token is string;
    }

    // 打刻修正申請
    match /stampCorrections/{correctionId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.empId is string
                            && request.resource.data.status in ['pending', 'approved', 'rejected', 'completed'];
    }

    // エラーログ
    match /errorLogs/{logId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.message is string;
    }
  }
}
