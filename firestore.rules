rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isValidStatus(status) {
      return status in ['pending', 'approved', 'rejected', 'completed', 'canceled'];
    }

    // すべてのドキュメントに対して、今は開発・運用を優先しつつ最低限のガードをかける
    match /{document=**} {
      allow read, write: if true;
    }

    // 個別の詳細バリデーション（必要に応じて将来的に強化可能）
    // 現状は permission error を回避するため全体を許可にしていますが、
    // ここにサブマッチを書くことで特定の制限を追加できます。
  }
}
