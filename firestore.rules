rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ヘルパー: 有効なステータス値か判定
    function isValidStatus(status) {
      return status in ['pending', 'approved', 'rejected', 'completed', 'canceled'];
    }

    // ヘルパー: Firebase Auth で認証済みか判定
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- 従業員コレクション ---
    // 読み取り: 全許可（従業員選択画面で使用）
    // 書き込み: 認証済みユーザーのみ（管理者限定）
    match /employees/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // --- 勤怠記録 ---
    // 読み取り: 全許可（リアルタイム表示に使用）
    // 書き込み: empId が空でないことを検証
    match /attendance/{docId} {
      allow read: if true;
      allow create: if request.resource.data.empId is string
                    && request.resource.data.empId.size() > 0;
      allow update: if true;
      allow delete: if isAuthenticated();
    }

    // --- 申請 ---
    // 読み取り: 全許可
    // 作成: empId と type が必須
    // 更新: ステータスの変更のみ許可
    // 削除: 認証済みユーザーのみ（管理者限定）
    match /applications/{docId} {
      allow read: if true;
      allow create: if request.resource.data.empId is string
                    && request.resource.data.empId.size() > 0
                    && request.resource.data.type is string;
      allow update: if isValidStatus(request.resource.data.status);
      allow delete: if isAuthenticated();
    }

    // --- 打刻修正申請 ---
    match /stampCorrections/{docId} {
      allow read: if true;
      allow create: if request.resource.data.empId is string
                    && request.resource.data.empId.size() > 0
                    && request.resource.data.reason is string;
      allow update: if isValidStatus(request.resource.data.status);
      allow delete: if isAuthenticated();
    }

    // --- パスワードリセットトークン ---
    // 作成: トークンと empId が必須
    // 読み取り: トークン検証に使用
    // 削除: 使用済みトークンの削除に使用
    match /passwordResetTokens/{docId} {
      allow read: if true;
      allow create: if request.resource.data.token is string
                    && request.resource.data.empId is string;
      allow update: if false;
      allow delete: if true;
    }

    // --- 有給付与履歴 ---
    match /leaveGrants/{docId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // --- 祝日 ---
    match /holidays/{docId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // --- システム設定 ---
    // 読み取り: 全許可（GAS URLの取得に使用）
    // 書き込み: 認証済みユーザーのみ（管理者限定）
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // --- エラーログ ---
    match /errorLogs/{docId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
  }
}
